#!/usr/bin/env bash
# bin/dev - one command to bring up the full hydrodactyl dev stack.
# Idempotent. Re-runnable on any branch.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

log()  { printf '\033[1;34m[dev]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[dev]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[dev]\033[0m %s\n' "$*" >&2; exit 1; }

# 1. Docker daemon up?
if ! docker info >/dev/null 2>&1; then
  die "Docker daemon not running. Start Docker (or colima/podman socket) and retry."
fi

# 2. .env in repo root (so host-side tooling like `php artisan` from IDE works)
if [ ! -f .env ]; then
  log "Creating .env from .env.example"
  cp .env.example .env
fi

# 2b. Port-collision guard for PANEL_PORT (default 3000).
# If something else owns the port, bump to the next free one and persist to .env.
PANEL_PORT="${PANEL_PORT:-$(grep -E '^PANEL_PORT=' .env 2>/dev/null | cut -d= -f2 | tail -1 || true)}"
PANEL_PORT="${PANEL_PORT:-3000}"

pick_free_port() {
  local start="$1"
  local p="$start"
  while [ "$p" -lt 65535 ]; do
    if ! ss -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}\$"; then
      echo "$p"; return 0
    fi
    p=$((p+1))
  done
  return 1
}

if ss -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${PANEL_PORT}\$"; then
  FREE_PORT=$(pick_free_port "$PANEL_PORT") || die "No free port found above ${PANEL_PORT}."
  warn "Port ${PANEL_PORT} already in use; switching PANEL_PORT=${FREE_PORT}"
  # Persist for next runs.
  if grep -qE '^PANEL_PORT=' .env; then
    sed -i "/^PANEL_PORT=/d" .env && echo "PANEL_PORT=${FREE_PORT}" >> .env
  else
    echo "PANEL_PORT=${FREE_PORT}" >> .env
  fi
  PANEL_PORT="$FREE_PORT"
  export PANEL_PORT
fi

# Also check the other dev ports (mailpit UI 8025, minio 9001, elytra 8080/2022)
for p in 8025 9001 8080 2022; do
  if ss -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}\$"; then
    warn "Port ${p} in use. Service on that port may be unreachable; pick a different stack or stop the other container."
  fi
done

# 3. Ensure dirs the compose file mounts
log "Ensuring srv/ subdirectories"
mkdir -p srv/{database,var,nginx,certs,logs,pterodactyl/config,data1-1,data1-2} \
         srv/elytra/{tmp,docker/containers,logs} \
         data/mailpit
chmod -R 777 srv data 2>/dev/null || true

# 4. Bring up the stack. --build only when Dockerfile or panel context changed.
COMPOSE="docker compose -f docker-compose.develop.yml"
NEEDS_BUILD=0
if ! docker image inspect hydrodactyl:develop >/dev/null 2>&1; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" = "1" ]; then
  log "Building hydrodactyl:develop image (first run, slow)"
  $COMPOSE build panel
fi

log "Starting stack (panel, db, cache, mailpit, minio, elytra)"
$COMPOSE up -d

# 5. Wait for panel container to be ready (nginx/PHP accepting connections)
log "Waiting for panel at http://localhost:${PANEL_PORT} ..."
REQUEST_COUNT=0
for i in $(seq 1 120); do
  HTTP_CODE=$(curl -s -o /dev/null -w '%{http_code}' "http://localhost:${PANEL_PORT}/" 2>/dev/null || echo "000")
  if [ "$HTTP_CODE" != "000" ]; then
    REQUEST_COUNT=$((REQUEST_COUNT + 1))
    if [ "$REQUEST_COUNT" -ge 3 ]; then
      log "Panel is up (responding after entrypoint)."
      break
    fi
  fi
  if [ "$i" -eq 120 ]; then
    warn "Panel did not respond in 120s. Tail: $COMPOSE logs --tail=50 panel"
  fi
  sleep 2
done

# 6. Start Vite dev server for HMR (if not already running)
if ! $COMPOSE exec -T panel sh -c 'test -f /app/public/hot' 2>/dev/null; then
  log "Starting Vite dev server (HMR) inside panel container..."
  $COMPOSE exec -d panel pnpm run dev -- --host 2>/dev/null || true
  # Give Vite a moment to boot
  for i in $(seq 1 15); do
    if $COMPOSE exec -T panel sh -c 'test -f /app/public/hot' 2>/dev/null; then
      log "Vite dev server ready."
      break
    fi
    sleep 1
  done
fi

# 7. The entrypoint writes elytra config.yml to the shared volume during seeding.
#    Restart elytra so it picks up the fresh config.
log "Restarting elytra to pick up daemon config"
$COMPOSE restart elytra

cat <<EOF

$(printf '\033[1;32m')✔ hydrodactyl dev stack is up$(printf '\033[0m')

  Panel       http://localhost:${PANEL_PORT}          (login: admin / admin)
  Mailpit UI  http://localhost:8025
  MinIO UI    http://localhost:9001           (minioadmin / minioadmin)
  MariaDB     localhost:3306  (unexposed by default; see note below)
  Elytra/Wings 8080 (sftp) / 2022 (websocket)

Common commands (Makefile):
  make dev        # this script (idempotent)
  make logs       # tail panel logs
  make shell      # shell into the panel container
  make artisan CMD='migrate:status'
  make tinker
  make fe-build   # build frontend assets (resources/scripts -> public/build)
  make fe-watch   # Vite HMR (needs Node 22.13+ on host)
  make stop       # stop stack, keep data
  make nuke       # stop stack + delete srv/ and vendor cache (full reset)

On any branch: just run \`make dev\`. Volumes persist, code is bind-mounted,
so \`git switch <branch>\` + \`make dev\` is enough.

To expose MariaDB to host: uncomment the \`ports: ['3306:3306']\` block
under \`database:\` in docker-compose.develop.yml.

EOF
